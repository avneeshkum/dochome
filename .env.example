# Supabase (get these from Project Settings -> API in your Supabase dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# WhatsApp Cloud API (set these in Vercel Project Settings -> Environment Variables,
# NOT in this file for production - this file is only for local reference)
# Get these from Meta for Developers -> your app -> WhatsApp -> API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-temporary-or-permanent-access-token

# Comma-separated list of team WhatsApp numbers in international format (no +, no spaces)
# e.g. 919876543210,919812345678
WHATSAPP_TEAM_NUMBERS=
